{
  "name": "flowdeck",
  "version": "0.4.10",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "license": "MIT",
  "author": "zjy4fun",
  "description": "FlowDeck is a focus-first desktop terminal workspace for agentic coding",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "node scripts/build.mjs",
    "start": "node scripts/build.mjs && electron .",
    "pack": "node scripts/build.mjs && electron-builder --dir",
    "dist": "node scripts/build.mjs && electron-builder",
    "release": "bumpp --all --commit --tag --push",
    "release:dry": "bumpp --all"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "bumpp": "^11.0.1",
    "electron": "^36.0.0",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.2.0-beta.12"
  }
}
